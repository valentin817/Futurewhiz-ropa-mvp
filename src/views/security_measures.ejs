<%- include('partials/header', { pageTitle, user, currentPath, flash }) %>

<section class="page-header">
  <div>
    <span class="eyebrow">Security register</span>
    <h1>Security measures</h1>
  </div>
  <div class="header-actions">
    <button class="button secondary" type="button" data-search-toggle aria-expanded="<%= activeFilters.length ? 'true' : 'false' %>">Search</button>
    <button class="button secondary" type="button" data-new-category-toggle aria-expanded="<%= showNewForm ? 'true' : 'false' %>">New category</button>
    <a class="button secondary" href="/exports/security-measures.pdf<%= exportQuery ? `?${exportQuery}` : '' %>">Export PDF</a>
  </div>
</section>

<section class="panel search-panel <%= activeFilters.length ? 'is-open' : '' %>" data-search-panel <%= activeFilters.length ? '' : 'hidden' %>>
  <div class="register-toolbar">
    <div>
      <h2>Search and filters</h2>
      <p>Search across category names and the text recorded inside each category.</p>
    </div>
  </div>

  <form class="filters-grid" method="get" action="/security-measures">
    <label class="span-2">
      <span>Keyword search</span>
      <input type="text" name="q" value="<%= filters.q %>" placeholder="Search category or recorded security measures" />
    </label>

    <label>
      <span>Sort by</span>
      <select name="sort">
        <option value="name_asc" <%= filters.sort === 'name_asc' ? 'selected' : '' %>>Category</option>
        <option value="updated_desc" <%= filters.sort === 'updated_desc' ? 'selected' : '' %>>Last updated</option>
      </select>
    </label>

    <div class="filter-actions span-2">
      <button class="button" type="submit">Apply filters</button>
      <a class="button ghost" href="/security-measures">Reset</a>
    </div>
  </form>
</section>

<section class="panel security-create-panel <%= showNewForm ? 'is-open' : '' %>" data-new-category-panel <%= showNewForm ? '' : 'hidden' %>>
  <div class="section-heading">
    <div>
      <h2>New category</h2>
      <p>Add a new security measure category with a text box for the recorded measures.</p>
    </div>
  </div>

  <% if (formErrors.length > 0) { %>
    <div class="flash flash-error">
      <ul class="bullet-list">
        <% formErrors.forEach((error) => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form class="form-grid" method="post" action="/security-measures">
    <label>
      <span>Category name</span>
      <input type="text" name="name" value="<%= formValues.name %>" />
    </label>

    <label class="span-2">
      <span>Security measures</span>
      <textarea name="notes" rows="8" placeholder="- Add the security measures recorded under this category"><%= formValues.notes %></textarea>
    </label>

    <div class="form-actions span-2">
      <button class="button" type="submit">Save category</button>
    </div>
  </form>
</section>

<section class="register-card-list">
  <% if (activeFilters.length) { %>
    <div class="active-filter-list">
      <% activeFilters.forEach((filter) => { %>
        <span class="filter-chip"><%= filter %></span>
      <% }) %>
    </div>
  <% } %>

  <% if (categories.length === 0) { %>
    <section class="panel">
      <p class="muted">No security measure categories matched the selected filters.</p>
    </section>
  <% } else { %>
    <section class="security-category-stack">
      <% categories.forEach((category) => { %>
        <article class="panel compliance-sheet security-category-sheet">
          <div class="security-category-head">
            <div>
              <h2><%= category.name %></h2>
            </div>
            <span class="muted"><%= formatDateTime(category.updated_at || category.created_at) %></span>
          </div>

          <form class="stack security-category-form" method="post" action="/security-measures/<%= category.id %>">
            <label class="security-category-field">
              <span>Security measures</span>
              <textarea class="security-category-notes" name="notes" rows="9"><%= category.notes %></textarea>
            </label>

            <div class="form-actions">
              <button class="button" type="submit">Save category</button>
            </div>
          </form>
        </article>
      <% }) %>
    </section>
  <% } %>
</section>

<script>
  const searchToggle = document.querySelector('[data-search-toggle]');
  const searchPanel = document.querySelector('[data-search-panel]');
  const newCategoryToggle = document.querySelector('[data-new-category-toggle]');
  const newCategoryPanel = document.querySelector('[data-new-category-panel]');

  if (searchToggle && searchPanel) {
    searchToggle.addEventListener('click', () => {
      const isHidden = searchPanel.hasAttribute('hidden');
      if (isHidden) {
        searchPanel.removeAttribute('hidden');
        searchPanel.classList.add('is-open');
        searchToggle.setAttribute('aria-expanded', 'true');
      } else {
        searchPanel.setAttribute('hidden', '');
        searchPanel.classList.remove('is-open');
        searchToggle.setAttribute('aria-expanded', 'false');
      }
    });
  }

  if (newCategoryToggle && newCategoryPanel) {
    newCategoryToggle.addEventListener('click', () => {
      const isHidden = newCategoryPanel.hasAttribute('hidden');
      if (isHidden) {
        newCategoryPanel.removeAttribute('hidden');
        newCategoryPanel.classList.add('is-open');
        newCategoryToggle.setAttribute('aria-expanded', 'true');
      } else {
        newCategoryPanel.setAttribute('hidden', '');
        newCategoryPanel.classList.remove('is-open');
        newCategoryToggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>

<%- include('partials/footer') %>
