<%- include('partials/header', { pageTitle, user, currentPath, flash }) %>

<section class="page-header">
  <div>
    <span class="eyebrow">Security register</span>
    <h1>Security measures</h1>
    <p>Maintain reusable technical and organisational measures as individual cards instead of fictional activity summaries.</p>
  </div>
  <div class="header-actions">
    <button class="button secondary" type="button" data-search-toggle aria-expanded="<%= activeFilters.length ? 'true' : 'false' %>">Search</button>
    <button class="button secondary" type="button" data-new-measure-toggle aria-expanded="<%= showNewForm ? 'true' : 'false' %>">New security measure</button>
    <a class="button secondary" href="/exports/security-measures.pdf<%= exportQuery ? `?${exportQuery}` : '' %>">Export PDF</a>
  </div>
</section>

<section class="panel search-panel <%= activeFilters.length ? 'is-open' : '' %>" data-search-panel <%= activeFilters.length ? '' : 'hidden' %>>
  <div class="register-toolbar">
    <div>
      <h2>Search and filters</h2>
      <p>Filter the security register by keyword or category.</p>
    </div>
  </div>

  <form class="filters-grid" method="get" action="/security-measures">
    <label class="span-2">
      <span>Keyword search</span>
      <input type="text" name="q" value="<%= filters.q %>" placeholder="Search title, description, or category" />
    </label>

    <label>
      <span>Category</span>
      <select name="category">
        <option value="">All categories</option>
        <% categoryOptions.forEach((category) => { %>
          <option value="<%= category %>" <%= filters.category === category ? 'selected' : '' %>><%= category %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Sort by</span>
      <select name="sort">
        <option value="category_asc" <%= filters.sort === 'category_asc' ? 'selected' : '' %>>Category</option>
        <option value="title_asc" <%= filters.sort === 'title_asc' ? 'selected' : '' %>>Title</option>
        <option value="updated_desc" <%= filters.sort === 'updated_desc' ? 'selected' : '' %>>Last updated</option>
      </select>
    </label>

    <div class="filter-actions span-2">
      <button class="button" type="submit">Apply filters</button>
      <a class="button ghost" href="/security-measures">Reset</a>
    </div>
  </form>
</section>

<section class="panel security-create-panel <%= showNewForm ? 'is-open' : '' %>" data-new-measure-panel <%= showNewForm ? '' : 'hidden' %>>
  <div class="section-heading">
    <div>
      <h2>New security measure</h2>
      <p>Add a reusable measure card with a category, title, and description.</p>
    </div>
  </div>

  <% if (formErrors.length > 0) { %>
    <div class="flash flash-error">
      <ul class="bullet-list">
        <% formErrors.forEach((error) => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form class="form-grid" method="post" action="/security-measures">
    <label>
      <span>Category</span>
      <input type="text" name="category" value="<%= formValues.category %>" list="security-category-options" />
    </label>

    <label>
      <span>Title</span>
      <input type="text" name="title" value="<%= formValues.title %>" />
    </label>

    <label class="span-2">
      <span>Description</span>
      <textarea name="description" rows="4"><%= formValues.description %></textarea>
    </label>

    <div class="form-actions span-2">
      <button class="button" type="submit">Save security measure</button>
    </div>
  </form>

  <datalist id="security-category-options">
    <% categoryOptions.forEach((category) => { %>
      <option value="<%= category %>"></option>
    <% }) %>
  </datalist>
</section>

<section class="register-card-list">
  <% if (activeFilters.length) { %>
    <div class="active-filter-list">
      <% activeFilters.forEach((filter) => { %>
        <span class="filter-chip"><%= filter %></span>
      <% }) %>
    </div>
  <% } %>

  <% if (measures.length === 0) { %>
    <section class="panel">
      <p class="muted">No security measures matched the selected filters.</p>
    </section>
  <% } else { %>
    <section class="security-measure-grid">
      <% measures.forEach((measure) => { %>
        <article class="panel security-measure-card">
          <div class="security-measure-card-head">
            <strong>Security measure</strong>
            <span class="muted"><%= formatDateTime(measure.updated_at || measure.created_at) %></span>
          </div>
          <div class="security-measure-record">
            <div class="security-measure-row">
              <span class="security-measure-label">Category</span>
              <span class="security-measure-value security-measure-category"><%= measure.category %></span>
            </div>
            <div class="security-measure-row">
              <span class="security-measure-label">Measure</span>
              <span class="security-measure-value"><%= measure.title %></span>
            </div>
            <div class="security-measure-row">
              <span class="security-measure-label">Description</span>
              <span class="security-measure-value"><%= measure.description %></span>
            </div>
          </div>
        </article>
      <% }) %>
    </section>
  <% } %>
</section>

<script>
  const searchToggle = document.querySelector('[data-search-toggle]');
  const searchPanel = document.querySelector('[data-search-panel]');
  const newMeasureToggle = document.querySelector('[data-new-measure-toggle]');
  const newMeasurePanel = document.querySelector('[data-new-measure-panel]');

  if (searchToggle && searchPanel) {
    searchToggle.addEventListener('click', () => {
      const isHidden = searchPanel.hasAttribute('hidden');
      if (isHidden) {
        searchPanel.removeAttribute('hidden');
        searchPanel.classList.add('is-open');
        searchToggle.setAttribute('aria-expanded', 'true');
      } else {
        searchPanel.setAttribute('hidden', '');
        searchPanel.classList.remove('is-open');
        searchToggle.setAttribute('aria-expanded', 'false');
      }
    });
  }

  if (newMeasureToggle && newMeasurePanel) {
    newMeasureToggle.addEventListener('click', () => {
      const isHidden = newMeasurePanel.hasAttribute('hidden');
      if (isHidden) {
        newMeasurePanel.removeAttribute('hidden');
        newMeasurePanel.classList.add('is-open');
        newMeasureToggle.setAttribute('aria-expanded', 'true');
      } else {
        newMeasurePanel.setAttribute('hidden', '');
        newMeasurePanel.classList.remove('is-open');
        newMeasureToggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>

<%- include('partials/footer') %>
