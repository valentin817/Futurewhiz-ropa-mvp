<%- include('partials/header', { pageTitle, user, currentPath, flash }) %>

<section class="page-header">
  <div>
    <span class="eyebrow">Legal/privacy workspace</span>
    <h1>RoPA dashboard</h1>
    <p>Track register completeness, review workload, and change-driven updates from one internal workspace.</p>
  </div>
  <div class="header-actions">
    <a class="button secondary" href="/intake">New intake</a>
    <a class="button" href="/activities/new">Create activity</a>
  </div>
</section>

<section class="stats-grid">
  <% summaryCards.forEach((card) => { %>
    <a class="stat-card" href="<%= card.href %>">
      <span class="stat-label"><%= card.label %></span>
      <strong class="stat-value"><%= card.value %></strong>
    </a>
  <% }) %>
</section>

<section class="content-grid">
  <article class="panel">
    <div class="section-heading">
      <div>
        <h2>Upcoming and overdue reviews</h2>
        <p>Records due now or soon, ordered by next review date.</p>
      </div>
      <a class="text-link" href="/activities?sort=next_review_asc">Open register</a>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Reference</th>
            <th>Activity</th>
            <th>Status</th>
            <th>Owner</th>
            <th>Next review</th>
          </tr>
        </thead>
        <tbody>
          <% upcomingReviews.forEach((activity) => { %>
            <tr>
              <td><a href="/activities/<%= activity.id %>"><%= activity.reference_code %></a></td>
              <td>
                <strong><%= activity.activity_name %></strong>
                <div class="muted"><%= activity.product_service %></div>
              </td>
              <td><span class="status-pill <%= statusClass(activity.status) %>"><%= statusLabel(activity.status) %></span></td>
              <td><%= activity.business_owner_name %></td>
              <td>
                <%= activity.next_review_date ? formatDate(activity.next_review_date) : 'Not set' %>
                <% if (activity.is_overdue) { %>
                  <div class="flag danger">Overdue</div>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="section-heading">
      <div>
        <h2>Recent intake requests</h2>
        <p>Trigger-based submissions from business teams.</p>
      </div>
      <a class="text-link" href="/intake">Submit intake</a>
    </div>
    <div class="timeline-list">
      <% intakeRequests.forEach((request) => { %>
        <div class="timeline-item">
          <div class="timeline-title"><%= request.title %></div>
          <div class="muted"><%= request.request_code %> · <%= request.requester_name %> · <%= formatDateTime(request.created_at) %></div>
          <p><%= request.summary %></p>
        </div>
      <% }) %>
    </div>
  </article>
</section>

<%- include('partials/footer') %>
