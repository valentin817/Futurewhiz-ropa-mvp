<%- include('partials/header', { pageTitle, user, currentPath, flash }) %>

<section class="page-header">
  <div>
    <span class="eyebrow"><%= activity.reference_code %></span>
    <h1><%= activity.activity_name %></h1>
    <p><%= activity.short_description %></p>
  </div>
  <div class="header-actions">
    <span class="status-pill <%= statusClass(activity.status) %>"><%= statusLabel(activity.status) %></span>
    <% if (canEdit) { %>
      <a class="button secondary" href="/activities/<%= activity.id %>/edit">Edit record</a>
    <% } %>
    <a class="button" href="/activities/<%= activity.id %>/export.pdf">Export PDF</a>
  </div>
</section>

<section class="panel compliance-sheet activity-review-sheet">
  <div class="sheet-section sheet-section-intro">
    <div class="sheet-section-header">
      <div>
        <h2>Processing activity review</h2>
        <p>One structured review sheet for ownership, processing details, security measures, and linked compliance items.</p>
      </div>
    </div>
    <dl class="detail-list activity-sheet-meta">
      <div>
        <dt>Status</dt>
        <dd><span class="status-pill <%= statusClass(activity.status) %>"><%= statusLabel(activity.status) %></span></dd>
      </div>
      <div>
        <dt>Futurewhiz role</dt>
        <dd><span class="role-badge <%= activity.futurewhiz_role %>"><%= futurewhizRoleLabel(activity.futurewhiz_role) %></span></dd>
      </div>
      <div>
        <dt>Owner</dt>
        <dd><%= activity.business_owner_name || 'Not set' %></dd>
      </div>
      <div>
        <dt>Legal reviewer</dt>
        <dd><%= activity.legal_reviewer_name || 'Not assigned' %></dd>
      </div>
      <div>
        <dt>Last review date</dt>
        <dd><%= activity.last_review_date ? formatDate(activity.last_review_date) : 'Not set' %></dd>
      </div>
      <div>
        <dt>Next review date</dt>
        <dd>
          <%= activity.next_review_date ? formatDate(activity.next_review_date) : 'Not set' %>
          <% if (activity.is_overdue) { %><span class="flag danger">Overdue</span><% } %>
        </dd>
      </div>
      <div>
        <dt>Last updated by</dt>
        <dd><%= activity.last_updated_by_name || activity.last_updated_by_email %></dd>
      </div>
      <div>
        <dt>Last updated</dt>
        <dd><%= formatDateTime(activity.last_updated_at) %></dd>
      </div>
    </dl>
  </div>

  <div class="sheet-divider"></div>

  <section class="sheet-section">
    <div class="sheet-section-header">
      <div>
        <h2>Ownership and accountability</h2>
      </div>
    </div>
    <dl class="detail-list sheet-detail-list">
      <div><dt>Joint controller</dt><dd><%= activity.joint_controller_name || 'Not applicable' %></dd></div>
      <div><dt>Controller representative</dt><dd><%= activity.controller_representative_name || 'Not applicable' %></dd></div>
      <div><dt>Data Protection Officer</dt><dd><%= activity.dpo_name || 'Not applicable' %></dd></div>
    </dl>
  </section>

  <div class="sheet-divider"></div>

  <section class="sheet-section">
    <div class="sheet-section-header">
      <div>
        <h2>Processing details</h2>
      </div>
    </div>
    <dl class="detail-list sheet-detail-list">
      <div><dt>Business process</dt><dd><%= activity.business_process || 'Not set' %></dd></div>
      <div><dt>Department</dt><dd><%= activity.department %></dd></div>
      <div><dt>Owner</dt><dd><%= activity.business_owner_name || 'Not set' %></dd></div>
      <div><dt>What?</dt><dd><%= activity.short_description || 'Not set' %></dd></div>
      <div><dt>Processes personal data?</dt><dd><%= activity.processes_personal_data ? 'Yes' : 'No' %></dd></div>
      <div><dt>Product / service</dt><dd><%= activity.product_service %></dd></div>
      <div><dt>Used for what within FutureWhiz?</dt><dd><%= activity.futurewhiz_internal_use || 'Not set' %></dd></div>
      <div><dt>Purpose of processing? Why do we use this?</dt><dd><%= activity.purpose_of_processing %></dd></div>
      <div><dt>Processing lawful?</dt><dd><%= activity.processing_lawful ? 'Yes' : 'No' %></dd></div>
      <div><dt>Type of processing</dt><dd><%= activity.processing_type || 'Not set' %></dd></div>
      <div><dt>Lawful basis</dt><dd><%= activity.lawful_basis || 'Not set' %></dd></div>
      <div><dt>Category of data subject? (i.e. children, parents, schools, future / former customers,..)</dt><dd><%= activity.data_subject_categories.length ? activity.data_subject_categories.join(', ') : 'Not set' %></dd></div>
      <div><dt>What personal data is processed?</dt><dd><%= activity.personal_data_categories.length ? activity.personal_data_categories.join(', ') : 'Not set' %></dd></div>
      <div><dt>Category of recipients to whom personal data will be disclosed (i.e. regulatory bodies, other third parties,...)</dt><dd><%= activity.recipient_categories.length ? activity.recipient_categories.join(', ') : 'Not set' %></dd></div>
      <div><dt>Processors / vendors</dt><dd><%= activity.processors_vendors.length ? activity.processors_vendors.join(', ') : 'Not set' %></dd></div>
      <div><dt>International transfers</dt><dd><%= activity.international_transfers ? 'Yes' : 'No' %></dd></div>
      <div><dt>Data within EU?</dt><dd><%= activity.data_within_eu ? 'Yes' : 'No' %></dd></div>
      <div><dt>Transfer safeguards</dt><dd><%= activity.transfer_mechanisms.length ? activity.transfer_mechanisms.join(', ') : 'Not set' %></dd></div>
      <div><dt>Transfer countries</dt><dd><%= activity.transfer_countries.length ? activity.transfer_countries.join(', ') : 'Not set' %></dd></div>
      <div><dt>Storage term + term when data should be deleted</dt><dd><%= activity.retention_period || 'Missing retention period' %></dd></div>
      <div><dt>Storage term internally used</dt><dd><%= activity.retention_period_internal || 'Not set' %></dd></div>
      <div><dt>How is enforcement of the internal storage term currently carried out?</dt><dd><%= activity.retention_enforcement || 'Not set' %></dd></div>
      <div><dt>Is 'old' data deleted (Y/N)? If Y, when (date).</dt><dd><%= activity.old_data_deletion_details || 'Not set' %></dd></div>
      <div><dt>Signed the 'new' Processor agreement which is compliant to the GDPR?</dt><dd><%= activity.processor_agreement_signed ? 'Yes' : 'No' %></dd></div>
      <div><dt>TIA performed?</dt><dd><%= activity.tia_performed ? 'Yes' : 'No' %></dd></div>
      <div><dt>Source of personal data</dt><dd><%= activity.source_of_personal_data || 'Not set' %></dd></div>
      <div><dt>Children’s data</dt><dd><%= activity.children_data ? 'Yes' : 'No' %></dd></div>
      <div><dt>Special category data</dt><dd><%= activity.special_category_data ? 'Yes' : 'No' %></dd></div>
      <div><dt>AI systems involved</dt><dd><%= activity.ai_involvement ? 'Yes' : 'No' %></dd></div>
      <div><dt>Legal remarks</dt><dd><%= activity.legal_remarks || 'Not set' %></dd></div>
      <div><dt>Action required?</dt><dd><%= activity.action_required || 'Not set' %></dd></div>
    </dl>
  </section>

  <div class="sheet-divider"></div>

  <section class="sheet-section security-section" id="security-measures">
    <div class="sheet-section-header">
      <div>
        <h2>Security measures</h2>
        <p>This field is mandatory and intentionally highlighted for Article 30 review.</p>
      </div>
      <a class="button ghost" href="/activities/<%= activity.id %>/security-export.pdf">Export security PDF</a>
    </div>
    <div class="rich-text security-sheet-copy"><%= activity.security_measures || 'Missing security measures' %></div>
    <% if (activity.missing_security_measures) { %>
      <div class="flag danger">Security measures missing</div>
    <% } %>
  </section>

  <div class="sheet-divider"></div>

  <section class="sheet-section">
    <div class="sheet-section-header">
      <div>
        <h2>Linked compliance items</h2>
      </div>
      <% if (canEdit) { %>
        <details class="attachment-upload-toggle">
          <summary><span class="button secondary">Attach file</span></summary>
          <form class="inline-form-card attachment-upload-card" method="post" action="/activities/<%= activity.id %>/attachments" enctype="multipart/form-data">
            <select name="attachment_type">
              <% attachmentTypeOptions.forEach((option) => { %>
                <option value="<%= option.value %>"><%= option.label %></option>
              <% }) %>
            </select>
            <input type="text" name="label" placeholder="Optional label" />
            <input type="file" name="files" multiple />
            <button class="button secondary" type="submit">Upload</button>
          </form>
        </details>
      <% } %>
    </div>
    <dl class="detail-list sheet-detail-list">
      <div>
        <dt>Vendor review / DPA</dt>
        <dd>
          <%= activity.vendor_review_ref || 'Missing' %>
          <% if (activity.vendor_review_url) { %><a class="inline-link" href="<%= activity.vendor_review_url %>">Open</a><% } %>
          <% if (attachmentGroups.vendor_file.length) { %>
            <div class="attachment-list compliance-attachment-list">
              <% attachmentGroups.vendor_file.forEach((attachment) => { %>
                <div class="attachment-item">
                  <div>
                    <strong><%= attachment.label || attachment.original_name %></strong>
                    <div class="muted">uploaded <%= formatDateTime(attachment.uploaded_at) %></div>
                  </div>
                  <a class="button ghost" href="/attachments/<%= attachment.id %>/download">Download</a>
                </div>
              <% }) %>
            </div>
          <% } %>
        </dd>
      </div>
      <div>
        <dt>DPIA</dt>
        <dd>
          <%= activity.dpia_ref || 'Missing' %>
          <% if (activity.dpia_url) { %><a class="inline-link" href="<%= activity.dpia_url %>">Open</a><% } %>
          <% if (attachmentGroups.dpia.length) { %>
            <div class="attachment-list compliance-attachment-list">
              <% attachmentGroups.dpia.forEach((attachment) => { %>
                <div class="attachment-item">
                  <div>
                    <strong><%= attachment.label || attachment.original_name %></strong>
                    <div class="muted">uploaded <%= formatDateTime(attachment.uploaded_at) %></div>
                  </div>
                  <a class="button ghost" href="/attachments/<%= attachment.id %>/download">Download</a>
                </div>
              <% }) %>
            </div>
          <% } %>
        </dd>
      </div>
      <div>
        <dt>LIA</dt>
        <dd>
          <%= activity.lia_ref || 'Not linked' %>
          <% if (activity.lia_url) { %><a class="inline-link" href="<%= activity.lia_url %>">Open</a><% } %>
          <% if (attachmentGroups.lia.length) { %>
            <div class="attachment-list compliance-attachment-list">
              <% attachmentGroups.lia.forEach((attachment) => { %>
                <div class="attachment-item">
                  <div>
                    <strong><%= attachment.label || attachment.original_name %></strong>
                    <div class="muted">uploaded <%= formatDateTime(attachment.uploaded_at) %></div>
                  </div>
                  <a class="button ghost" href="/attachments/<%= attachment.id %>/download">Download</a>
                </div>
              <% }) %>
            </div>
          <% } %>
        </dd>
      </div>
      <div>
        <dt>Privacy notice section</dt>
        <dd>
          <%= activity.privacy_notice_ref || 'Not linked' %>
          <% if (activity.privacy_notice_url) { %><a class="inline-link" href="<%= activity.privacy_notice_url %>">Open</a><% } %>
          <% if (attachmentGroups.privacy_notice.length) { %>
            <div class="attachment-list compliance-attachment-list">
              <% attachmentGroups.privacy_notice.forEach((attachment) => { %>
                <div class="attachment-item">
                  <div>
                    <strong><%= attachment.label || attachment.original_name %></strong>
                    <div class="muted">uploaded <%= formatDateTime(attachment.uploaded_at) %></div>
                  </div>
                  <a class="button ghost" href="/attachments/<%= attachment.id %>/download">Download</a>
                </div>
              <% }) %>
            </div>
          <% } %>
        </dd>
      </div>
      <div>
        <dt>Security review</dt>
        <dd>
          <%= activity.security_review_ref || 'Missing' %>
          <% if (activity.security_review_url) { %><a class="inline-link" href="<%= activity.security_review_url %>">Open</a><% } %>
          <% if (attachmentGroups.security_review.length) { %>
            <div class="attachment-list compliance-attachment-list">
              <% attachmentGroups.security_review.forEach((attachment) => { %>
                <div class="attachment-item">
                  <div>
                    <strong><%= attachment.label || attachment.original_name %></strong>
                    <div class="muted">uploaded <%= formatDateTime(attachment.uploaded_at) %></div>
                  </div>
                  <a class="button ghost" href="/attachments/<%= attachment.id %>/download">Download</a>
                </div>
              <% }) %>
            </div>
          <% } %>
        </dd>
      </div>
      <div>
        <dt>AI tool review</dt>
        <dd>
          <%= activity.ai_tool_review_ref || 'Not linked' %>
          <% if (activity.ai_tool_review_url) { %><a class="inline-link" href="<%= activity.ai_tool_review_url %>">Open</a><% } %>
          <% if (attachmentGroups.ai_tool_review.length) { %>
            <div class="attachment-list compliance-attachment-list">
              <% attachmentGroups.ai_tool_review.forEach((attachment) => { %>
                <div class="attachment-item">
                  <div>
                    <strong><%= attachment.label || attachment.original_name %></strong>
                    <div class="muted">uploaded <%= formatDateTime(attachment.uploaded_at) %></div>
                  </div>
                  <a class="button ghost" href="/attachments/<%= attachment.id %>/download">Download</a>
                </div>
              <% }) %>
            </div>
          <% } %>
        </dd>
      </div>
      <div>
        <dt><%= attachmentTypeLabels.other %></dt>
        <dd>
          <% if (attachmentGroups.other.length === 0) { %>
            Not linked
          <% } else { %>
            <div class="attachment-list compliance-attachment-list">
              <% attachmentGroups.other.forEach((attachment) => { %>
                <div class="attachment-item">
                  <div>
                    <strong><%= attachment.label || attachment.original_name %></strong>
                    <div class="muted">uploaded <%= formatDateTime(attachment.uploaded_at) %></div>
                  </div>
                  <a class="button ghost" href="/attachments/<%= attachment.id %>/download">Download</a>
                </div>
              <% }) %>
            </div>
          <% } %>
        </dd>
      </div>
    </dl>
  </section>
</section>

<%- include('partials/footer') %>
