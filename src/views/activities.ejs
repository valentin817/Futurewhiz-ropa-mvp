<%- include('partials/header', { pageTitle, user, currentPath, flash }) %>

<section class="page-header">
  <div>
    <span class="eyebrow">Register</span>
    <h1>RoPA register</h1>
    <p>Open a processing activity to view the full record, then return with the back arrow or the Register tab.</p>
  </div>
  <div class="header-actions">
    <button class="button secondary" type="button" data-search-toggle aria-expanded="<%= activeFilters.length ? 'true' : 'false' %>">Search</button>
    <a class="button secondary" href="/exports/register.pdf<%= exportQuery ? `?${exportQuery}` : '' %>">Export PDF</a>
    <a class="button" href="/activities/new">New activity</a>
  </div>
</section>

<section class="panel search-panel <%= activeFilters.length ? 'is-open' : '' %>" data-search-panel <%= activeFilters.length ? '' : 'hidden' %>>
  <div class="register-toolbar">
    <div>
      <h2>Search and filters</h2>
      <p>Expand the full filter set only when you need it.</p>
    </div>
    <div class="header-actions">
      <a class="button secondary" href="/exports/register.xls<%= exportQuery ? `?${exportQuery}` : '' %>">Export Excel</a>
    </div>
  </div>

  <form class="filters-grid" method="get" action="/activities">
    <label class="span-2">
      <span>Keyword search</span>
      <input type="text" name="q" value="<%= filters.q %>" placeholder="Search activity, purpose, vendor, security measures, or reference" />
    </label>

    <label>
      <span>Futurewhiz role</span>
      <select name="futurewhiz_role">
        <option value="">All roles</option>
        <option value="controller" <%= filters.futurewhiz_role === 'controller' ? 'selected' : '' %>>Futurewhiz as controller</option>
        <option value="processor" <%= filters.futurewhiz_role === 'processor' ? 'selected' : '' %>>Futurewhiz as processor</option>
      </select>
    </label>

    <label>
      <span>Vendor</span>
      <select name="vendor">
        <option value="">All vendors</option>
        <% filterOptions.vendors.forEach((vendor) => { %>
          <option value="<%= vendor %>" <%= filters.vendor === vendor ? 'selected' : '' %>><%= vendor %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Product / service</span>
      <select name="product">
        <option value="">All products</option>
        <% filterOptions.products.forEach((product) => { %>
          <option value="<%= product %>" <%= filters.product === product ? 'selected' : '' %>><%= product %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Department</span>
      <select name="department">
        <option value="">All departments</option>
        <% filterOptions.departments.forEach((department) => { %>
          <option value="<%= department %>" <%= filters.department === department ? 'selected' : '' %>><%= department %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Business owner</span>
      <select name="owner">
        <option value="">All owners</option>
        <% filterOptions.owners.forEach((owner) => { %>
          <option value="<%= owner.email %>" <%= filters.owner === owner.email ? 'selected' : '' %>><%= owner.name %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Status</span>
      <select name="status">
        <option value="">All statuses</option>
        <% ['draft','pending_business_input','pending_legal_review','approved','needs_update','archived'].forEach((statusValue) => { %>
          <option value="<%= statusValue %>" <%= filters.status === statusValue ? 'selected' : '' %>><%= statusLabel(statusValue) %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Lawful basis</span>
      <select name="lawful_basis">
        <option value="">All lawful bases</option>
        <% filterOptions.lawfulBases.forEach((lawfulBasis) => { %>
          <option value="<%= lawfulBasis %>" <%= filters.lawful_basis === lawfulBasis ? 'selected' : '' %>><%= lawfulBasis %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Children’s data</span>
      <select name="children_data">
        <% booleanFilters.forEach((option) => { %>
          <option value="<%= option.value %>" <%= filters.children_data === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Special category data</span>
      <select name="special_category_data">
        <% booleanFilters.forEach((option) => { %>
          <option value="<%= option.value %>" <%= filters.special_category_data === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>International transfers</span>
      <select name="international_transfers">
        <% booleanFilters.forEach((option) => { %>
          <option value="<%= option.value %>" <%= filters.international_transfers === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>AI involvement</span>
      <select name="ai_involvement">
        <% booleanFilters.forEach((option) => { %>
          <option value="<%= option.value %>" <%= filters.ai_involvement === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Overdue review</span>
      <select name="overdue_review">
        <% booleanFilters.forEach((option) => { %>
          <option value="<%= option.value %>" <%= filters.overdue_review === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Missing linked items</span>
      <select name="missing_links">
        <option value="">Any</option>
        <option value="missing_dpia" <%= filters.missing_links === 'missing_dpia' ? 'selected' : '' %>>Missing DPIA</option>
        <option value="missing_vendor_review" <%= filters.missing_links === 'missing_vendor_review' ? 'selected' : '' %>>Missing vendor review / DPA</option>
        <option value="missing_security_review" <%= filters.missing_links === 'missing_security_review' ? 'selected' : '' %>>Missing security review</option>
        <option value="missing_any_core_link" <%= filters.missing_links === 'missing_any_core_link' ? 'selected' : '' %>>Missing any core linked item</option>
      </select>
    </label>

    <label>
      <span>Retention field</span>
      <select name="retention_state">
        <option value="all" <%= filters.retention_state === 'all' ? 'selected' : '' %>>Any</option>
        <option value="present" <%= filters.retention_state === 'present' ? 'selected' : '' %>>Retention present</option>
        <option value="missing" <%= filters.retention_state === 'missing' ? 'selected' : '' %>>Retention missing</option>
      </select>
    </label>

    <label>
      <span>Retention period contains</span>
      <input type="text" name="retention_search" value="<%= filters.retention_search %>" placeholder="e.g. 12 months" />
    </label>

    <label>
      <span>Security measures field</span>
      <select name="missing_security_measures">
        <% booleanFilters.forEach((option) => { %>
          <option value="<%= option.value %>" <%= filters.missing_security_measures === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }) %>
      </select>
    </label>

    <label>
      <span>Sort by</span>
      <select name="sort">
        <option value="next_review_asc" <%= filters.sort === 'next_review_asc' ? 'selected' : '' %>>Next review date</option>
        <option value="updated_desc" <%= filters.sort === 'updated_desc' ? 'selected' : '' %>>Last updated</option>
        <option value="activity_name_asc" <%= filters.sort === 'activity_name_asc' ? 'selected' : '' %>>Activity name</option>
        <option value="status_asc" <%= filters.sort === 'status_asc' ? 'selected' : '' %>>Status</option>
      </select>
    </label>

    <div class="filter-actions span-2">
      <button class="button" type="submit">Apply filters</button>
      <a class="button ghost" href="/activities">Reset</a>
    </div>
  </form>
</section>

<section class="register-card-list">
  <% if (activeFilters.length) { %>
    <div class="active-filter-list">
      <% activeFilters.forEach((filter) => { %>
        <span class="filter-chip"><%= filter %></span>
      <% }) %>
    </div>
  <% } %>

  <% if (activities.length === 0) { %>
    <section class="panel">
      <p class="muted">No activities matched the selected filters.</p>
    </section>
  <% } else { %>
    <section class="panel register-grid-panel">
      <div class="register-grid-head">
        <div>Activity</div>
        <div>Department</div>
        <div>Product</div>
        <div>Lawful basis</div>
        <div>Status</div>
        <div>Next review</div>
        <div>Owner</div>
      </div>

      <% activities.forEach((activity) => { %>
        <a class="register-grid-row" href="/activities/<%= activity.id %>">
          <div class="register-grid-activity">
            <strong><%= activity.activity_name %></strong>
            <span class="muted"><%= activity.short_description || 'No short description provided.' %></span>
          </div>
          <div><%= activity.department || 'Not set' %></div>
          <div><%= activity.product_service || 'Not set' %></div>
          <div><%= activity.lawful_basis || 'Not set' %></div>
          <div>
            <span class="status-pill <%= statusClass(activity.status) %>"><%= statusLabel(activity.status) %></span>
          </div>
          <div class="<%= activity.is_overdue ? 'review-date overdue' : 'review-date' %>">
            <%= activity.next_review_date ? formatDate(activity.next_review_date) : 'Not set' %>
            <% if (activity.is_overdue) { %>
              <span>(overdue)</span>
            <% } %>
          </div>
          <div><%= activity.business_owner_name || activity.business_owner_email || 'Not set' %></div>
        </a>
      <% }) %>
    </section>
  <% } %>
</section>

<script>
  const searchToggle = document.querySelector('[data-search-toggle]');
  const searchPanel = document.querySelector('[data-search-panel]');

  if (searchToggle && searchPanel) {
    searchToggle.addEventListener('click', () => {
      const isHidden = searchPanel.hasAttribute('hidden');
      if (isHidden) {
        searchPanel.removeAttribute('hidden');
        searchPanel.classList.add('is-open');
        searchToggle.setAttribute('aria-expanded', 'true');
      } else {
        searchPanel.setAttribute('hidden', '');
        searchPanel.classList.remove('is-open');
        searchToggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>

<%- include('partials/footer') %>
